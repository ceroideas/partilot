APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_DEBUG_MODE=false
MAIL_DEBUG_TO=

# Depuración PDF de diseño: en true, /design/pdf/participation|cover|back/{id} devuelve HTML en el navegador en lugar del PDF (rutas síncronas).
DESIGN_PDF_HTML_PREVIEW=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# API códigos prepago (recarga) — fallback PARTILOT cuando la administración marca "usar por defecto"
PREPAGO_CODIGOS_URL=https://www.test.elbuholotero.es/css/plugins/include/crea_codigos_prepago.php
PREPAGO_CODIGOS_APIKEY=
PREPAGO_CODIGOS_PREFIJO=c-

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Verificación teléfono por SMS (registro app + web comprador)
SMS_VERIFICATION_ENABLED=false
SMS_DRIVER=log
# Producción con httpSMS (móvil Android + línea): https://docs.httpsms.com/
# SMS_DRIVER=httpsms
SMS_CODE_LENGTH=6
SMS_CODE_TTL_MINUTES=10
SMS_RESEND_COOLDOWN_SECONDS=60
SMS_DEFAULT_COUNTRY_CODE=34

# httpSMS — pasarela SMS (app Android en el móvil de la entidad)
# API key: https://httpsms.com/settings
HTTPSMS_API_KEY=
HTTPSMS_FROM_NUMBER=+34XXXXXXXXX

# SMS venta digital al comprador (httpSMS). Si está desactivado, la app usa wa.me manual.
DIGITAL_SALE_SMS_ENABLED=false
# DIGITAL_SALE_SMS_DRIVER=httpsms
# DIGITAL_SALE_SMS_DRIVER=log
DIGITAL_SALE_SMS_DEFAULT_COUNTRY_CODE=34
# Máximo de reenvíos por venta pendiente (1 = primer SMS + 1 reenvío)
DIGITAL_SALE_SMS_MAX_RESENDS=1

# Venta digital: vinculación válida hasta N meses después de la fecha del sorteo (default 3)
DIGITAL_SALE_WALLET_VALIDITY_MONTHS=3
DIGITAL_SALE_LINK_CODE_LENGTH=6

# Sorteos: bloquear reservas/sets/diseños si draw_date ya pasó (true=producción, false=depuración)
LOTTERY_ENFORCE_DRAW_DATE_RULES=true

# Cierre automático: participaciones no devueltas tras fecha límite → vendidas + deuda
# false (default) = solo manual vía: php artisan sipart:lottery-deadline-closure --ignore-disabled
LOTTERY_AUTO_DEADLINE_CLOSURE_ENABLED=false
# LOTTERY_AUTO_DEADLINE_CLOSURE_USER_ID=1

# Avisos modal deadline 3/2/1/0: superadmin no los recibe por defecto
LOTTERY_DEADLINE_REMINDER_SUPERADMIN_MODAL=false
